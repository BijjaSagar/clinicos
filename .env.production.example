# ============================================
# ClinicOS Production Environment
# ============================================

APP_NAME="ClinicOS"
APP_ENV=production
APP_DEBUG=false
APP_URL=https://clinic0s.com
APP_DOMAIN=clinic0s.com
APP_KEY=

# ── Database ──────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=clinicos_prod
DB_USERNAME=
DB_PASSWORD=

# ── Cache & Session ──────────────────────────
CACHE_DRIVER=file
SESSION_DRIVER=file
QUEUE_CONNECTION=database
SESSION_LIFETIME=120

# ── Mail (SMTP) ──────────────────────────────
MAIL_MAILER=smtp
MAIL_HOST=smtp.hostinger.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@clinic0s.com
MAIL_FROM_NAME="ClinicOS"

# ── WhatsApp (Meta Cloud API) ────────────────
WHATSAPP_API_URL=https://graph.facebook.com/v19.0
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=clinicos_webhook_verify
WHATSAPP_APP_SECRET=

# ── Razorpay ─────────────────────────────────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# ── AWS S3 (Photo Vault) ─────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=ap-south-1
AWS_BUCKET=clinicos-photos
AWS_USE_PATH_STYLE_ENDPOINT=false

# ── OpenAI / Claude (AI Assistant) ───────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ── Error Monitoring ─────────────────────────
SENTRY_LARAVEL_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1

# ── Backup ───────────────────────────────────
BACKUP_DISK=local
BACKUP_NOTIFICATION_EMAIL=
