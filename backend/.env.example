APP_NAME=ClinicOS
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=https://clinic0s.com

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=clinicos
DB_USERNAME=root
DB_PASSWORD=

BROADCAST_DRIVER=log
CACHE_DRIVER=redis
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@clinicos.in"
MAIL_FROM_NAME="${APP_NAME}"

# AWS S3 for Photo Storage
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=ap-south-1
AWS_BUCKET=clinicos-photos
AWS_USE_PATH_STYLE_ENDPOINT=false

# Razorpay Payment Gateway
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxx
RAZORPAY_WEBHOOK_SECRET=

# WhatsApp Business API (Meta Cloud API)
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_VERIFY_TOKEN=clinicos_webhook_verify_2024
WHATSAPP_API_VERSION=v17.0

# ABDM (Ayushman Bharat Digital Mission)
ABDM_CLIENT_ID=
ABDM_CLIENT_SECRET=
ABDM_BASE_URL=https://dev.abdm.gov.in
ABDM_AUTH_URL=https://dev.abdm.gov.in/gateway/v0.5/sessions

# GSP (GST Suvidha Provider) for e-Invoice
GSP_BASE_URL=
GSP_API_KEY=
GSP_API_SECRET=

# OpenAI for AI features
OPENAI_API_KEY=

# Sanctum Configuration
SANCTUM_STATEFUL_DOMAINS=localhost,localhost:3000,localhost:8080,127.0.0.1,127.0.0.1:8000,::1

# JWT Configuration (for API auth)
JWT_SECRET=
JWT_TTL=60
JWT_REFRESH_TTL=20160
