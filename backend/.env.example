APP_NAME=ClinicOS
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000
APP_DOMAIN=clinic0s.com

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# =============================================
# DATABASE - MySQL
# =============================================
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=clinicos
DB_USERNAME=root
DB_PASSWORD=

# =============================================
# CACHE & SESSION
# =============================================
BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

# =============================================
# REDIS (Optional - for caching/queues)
# =============================================
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# =============================================
# MAIL - SMTP
# =============================================
MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@clinicos.com"
MAIL_FROM_NAME="${APP_NAME}"

# =============================================
# AWS S3 (Optional - for file storage)
# =============================================
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=ap-south-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# =============================================
# WHATSAPP BUSINESS API
# =============================================
WHATSAPP_API_URL=https://graph.facebook.com/v19.0
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=clinicos_webhook_verify
WHATSAPP_APP_SECRET=

# =============================================
# RAZORPAY (Payment Gateway)
# =============================================
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# =============================================
# ABDM / AYUSHMAN BHARAT
# =============================================
ABDM_CLIENT_ID=
ABDM_CLIENT_SECRET=
ABDM_BASE_URL=https://healthidsbx.abdm.gov.in

# =============================================
# SANCTUM - SPA Auth
# =============================================
SANCTUM_STATEFUL_DOMAINS=localhost,localhost:5173,127.0.0.1,127.0.0.1:8000

# =============================================
# OPENAI / CLAUDE (AI Features)
# =============================================
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# =============================================
# SENTRY (Error Monitoring)
# =============================================
SENTRY_LARAVEL_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
